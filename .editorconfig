# Cross-editor formatting consistency.
# https://editorconfig.org/
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.zig]
indent_style = space
indent_size = 4

[*.{yml,yaml,md,toml,zon,json}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2

[Justfile]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
