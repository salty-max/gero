; main.gas — project entry point.
;
; Prints "Hello, gero!\n" via the host `int $10` syscall, then
; halts. Run with `gero build && gero run out/<name>.gx`.

const PRINT   = $10
const NEWLINE = $0A

main:
  mov $00, r3                ; index = 0
.loop:
  mov8 [@GREETING + r3], r1
  cmp r1, $00
  jeq .done
  int PRINT
  inc r3
  jmp .loop
.done:
  mov NEWLINE, r1
  int PRINT
  hlt

data8 GREETING = "Hello, gero!", $00
